{
  "name": "guessit-js",
  "version": "3.9.0",
  "description": "Extract metadata (title, year, season, episode, codec, language, etc.) from media filenames — TypeScript port of Python guessit",
  "keywords": [
    "guessit",
    "media",
    "filename",
    "parser",
    "movie",
    "episode",
    "tv",
    "metadata",
    "video",
    "subtitle",
    "release",
    "scene",
    "codec",
    "resolution",
    "typescript"
  ],
  "license": "LGPL-3.0",
  "author": "OpenSubtitles",
  "homepage": "https://opensubtitles.github.io/guessit-js",
  "repository": {
    "type": "git",
    "url": "https://github.com/opensubtitles/guessit-js"
  },
  "bugs": {
    "url": "https://github.com/opensubtitles/guessit-js/issues"
  },
  "type": "module",
  "main": "./dist/guessit-js.cjs",
  "module": "./dist/guessit-js.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/guessit-js.js",
      "require": "./dist/guessit-js.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "start": "npx tsx server.ts",
    "wasm": "bash wasm/build.sh"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "binaryen": "^125.0.0",
    "js-yaml": "^4.1.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.6.0",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "rebulk-js": "^3.3.1"
  }
}
